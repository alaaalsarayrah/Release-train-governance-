# Next.js Environment Variables (Optional)

# Azure DevOps Configuration
# These are stored in .ado-config.json by the application
# Included here for documentation purposes only
# ADO_ORGANIZATION=your-org
# ADO_PROJECT=your-project
# ADO_PAT=your-personal-access-token

# Custom API endpoints (if needed)
# NEXT_PUBLIC_API_URL=https://api.example.com

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Feature flags (optional)
# NEXT_PUBLIC_ENABLE_ADO_SYNC=true
# NEXT_PUBLIC_ENABLE_THESIS_PARSING=true

# Durable remote SQLite (recommended for Vercel production)
# If set, the app uses this remote database instead of local requests.db.
# REQUESTS_DB_URL=libsql://your-database.turso.io
# REQUESTS_DB_AUTH_TOKEN=your-libsql-auth-token

# Optional aliases (equivalent to the vars above)
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=your-libsql-auth-token

# Note: Most configuration is handled via UI or stored in .ado-config.json
# This file is for documentation and future environment-specific variables
