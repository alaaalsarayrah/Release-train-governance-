{
  "name": "agentic-sdlc-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "doctor": "npx expo-doctor",
    "check:release": "node ./scripts/release-preflight.mjs",
    "check:release:ios": "node ./scripts/release-preflight.mjs --platform ios",
    "check:release:android": "node ./scripts/release-preflight.mjs --platform android",
    "build:android": "npx eas-cli build --platform android --profile production",
    "build:ios": "npx eas-cli build --platform ios --profile production",
    "submit:android": "npx eas-cli submit --platform android --profile production",
    "submit:ios": "npx eas-cli submit --platform ios --profile production",
    "release:android": "npm run check:release:android && npm run build:android && npm run submit:android",
    "release:ios": "npm run check:release:ios && npm run build:ios && npm run submit:ios"
  },
  "dependencies": {
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-webview": "13.12.5"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0"
  },
  "engines": {
    "node": ">=18"
  }
}
